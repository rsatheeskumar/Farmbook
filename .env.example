# ─────────────────────────────────────────────────────────────
# Kisan Saathi — Environment Variables
# Copy this to .env and fill your keys
# ─────────────────────────────────────────────────────────────

# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_ME

# Get from: https://openweathermap.org/api  (free tier, no card needed)
OPENWEATHER_API_KEY=REPLACE_ME

# Change to ngrok URL when testing on phone:
BASE_URL=http://localhost:8000

STORAGE_DIR=/tmp/kisan_files
DATABASE_URL=sqlite+aiosqlite:///./kisansaathi.db
